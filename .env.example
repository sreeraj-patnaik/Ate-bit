GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
APP_BASE_URL=http://127.0.0.1:8000
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=opportunityhub@local.dev
# SMTP settings (use if EMAIL_BACKEND is SMTP)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
# Firebase service account json path for mobile push notifications
FIREBASE_CREDENTIALS_PATH=
# Optional: path to tesseract executable for OCR on Windows
# Example: C:\\Program Files\\Tesseract-OCR\\tesseract.exe
TESSERACT_CMD=
